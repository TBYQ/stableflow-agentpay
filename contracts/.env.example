# Flare Coston2 RPC.
# Official public RPC: https://coston2-api.flare.network/ext/C/rpc
COSTON2_RPC_URL=https://coston2-api.flare.network/ext/C/rpc

# Private key for a Coston2-funded test wallet.
# Never commit a real private key. Keep it only in contracts/.env.
COSTON2_PRIVATE_KEY=

# Optional: used by scripts/record-demo-payment.js.
STABLEFLOW_PAYMENT_CONTRACT=
STABLEFLOW_PAYMENT_INTENT_ID=pi_001
STABLEFLOW_SERVICE_ID=premium-market-report
STABLEFLOW_PAYMENT_AMOUNT=0.001
